# ── Database ───────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/currencydb
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate a strong random base64 secret (min 32 bytes):
#   openssl rand -base64 64
JWT_SECRET=your-very-long-base64-encoded-secret-at-least-256-bits
JWT_EXPIRATION=86400000

# ── ExchangeRate-API ───────────────────────────────────────────────────────────
# Free tier key from https://www.exchangerate-api.com  (1500 req/month)
EXCHANGE_RATE_API_KEY=your_api_key_here

# ── Email (Gmail SMTP for rate alerts) ─────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password   # Use a Gmail App Password, not your account password

# ── CORS ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
